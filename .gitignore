# ESP-IDF build artifacts
build/
build_*_*/
bootloader/build/
*.elf
*.bin
*.map
*.dmp
coredump.elf
compile_commands.json

# Generated configuration (sdkconfig.defaults is the source of truth — sdkconfig
# is regenerated by every `idf.py build`. Direct edits to sdkconfig don't survive.)
sdkconfig
sdkconfig.old
sdkconfig.bak

# ESP-IDF dependency manager
dependencies.lock
managed_components/

# Log files and temporary files
*.log
*.o
*.pyc
__pycache__/
.pytest_cache/
pytest_embedded_log/

# IDEs
.vscode/
.idea/
.clangd
.ccls-cache/
*.swp
*.swo
*~
.cache/

# OS files
.DS_Store
Thumbs.db

# AI agent configuration and content (local only — never commit).
# Nothing AI-agent-specific belongs in the repo — different contributors may
# use different tools (Claude, Cursor, Copilot, Aider, Continue, Codeium,
# Tabnine, Sourcery, etc.) and committing one tool's config/content forces
# everyone else to deal with conflicts.
#
# This block covers (1) config files, (2) handoff/output bundles from any
# agent-assisted design or coding tool, and (3) chat-transcript scratch.
.claude
.claude/
.claude.md
CLAUDE.md
CLAUDE.MD
.cursorrules
.cursor/
.github/copilot*
.aider*
.continue/
.codeium/
.tabnine*
.sourcery.yaml
# Agent-produced handoff bundles (Claude Design, Copilot Workspace, v0, etc.)
**/agent-handoff/
**/*-handoff-bundle/

# Temporary/backup files
*.orig
*.tmp
*.bak

# Python tooling / virtualenvs (lv_font_conv etc. — generator-side tools)
.venv/
venv/
env/
node_modules/

# EEZ Studio UI state and backups (per-user editor state, not project data)
GUI/*.eez-project-ui-state
GUI/*.eez-project.bak*

# Phase-1 generator tooling. The .eez-project is now hand-edited through
# EEZ Studio's GUI (see "Authoring lifecycle" in the eezstudio skill), and
# the generator has been retired for this project. The ignore catches a
# leftover or revived tmp/ so a stale generator can't accidentally clobber
# GUI-made tweaks if someone runs it again.
tmp/
